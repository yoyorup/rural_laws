# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=rural_law_db
# macOS 本地 MySQL 通常需要 Unix socket（留空则用 TCP/IP）
MYSQL_UNIX_SOCKET=/tmp/mysql.sock

# Claude API Key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API Key (from https://platform.openai.com/)
# OPENAI_API_KEY=your_openai_api_key_here

# Qwen (Alibaba DashScope) API Key (from https://dashscope.aliyun.com/)
# QWEN_API_KEY=your_qwen_api_key_here

# GLM (Zhipu AI) API Key (from https://open.bigmodel.cn/)
# GLM_API_KEY=your_glm_api_key_here

# Gemini (Google) API Key (from https://aistudio.google.com/)
# GEMINI_API_KEY=your_gemini_api_key_here

# Default AI provider: claude | openai | qwen | glm | gemini (default: claude)
# DEFAULT_AI_PROVIDER=claude

# Optional: override model for each provider
# CLAUDE_MODEL=claude-opus-4-6
# OPENAI_MODEL=gpt-4o
# QWEN_MODEL=qwen-max
# GLM_MODEL=glm-4
# GEMINI_MODEL=gemini-2.0-flash

# Optional: override data directory
# DATA_DIR=./data

# Optional: override output directory
# OUTPUT_DIR=./output

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
